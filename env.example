# Copy this file to `.env` in the project root (rename to `.env`) and fill in real values.
# `.env` is gitignored — do not commit passwords or API keys.

# Windows: use `pip install "psycopg[binary]>=3.1"` (not plain `psycopg`) so the DB driver loads.

# PostgreSQL (after you create database `rag_agent` in pgAdmin or psql)
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD_HERE@localhost:5432/rag_agent

# With DATABASE_URL set, accounts live in Postgres (Argon2). Optional: copy old JSON users:
# python -m rag_agent.import_json_users

# New passwords (registration): default min 12 chars, letter + digit. Session lifetime (days):
# RAG_MIN_PASSWORD_LENGTH=12
# RAG_MAX_PASSWORD_LENGTH=128
# RAG_SESSION_EXPIRY_DAYS=7

# Only RAG_AGENT_ADMIN_USERNAMES (short logins) or name@orlanda.info — domain configurable:
# RAG_ALLOWED_EMAIL_DOMAIN=orlanda.info
# RAG_AGENT_ADMIN_USERNAMES=admin

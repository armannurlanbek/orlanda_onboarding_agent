# LLM API (OpenAI-compatible: OpenAI, Ollama, LM Studio, etc.)
OPENAI_API_BASE=http://localhost:1234/v1
OPENAI_API_KEY=not-needed-for-local

# Optional: model name (default used if not set)
OPENAI_MODEL=llama3.2

# Path to company knowledge folder (relative to project root)
KNOWLEDGE_DIR=company_knowledge

# ChromaDB persistence directory
CHROMA_DIR=data/chroma

# --- Monday.com connector (optional, per-user OAuth) ---
# If these are not set, Monday stays disabled and users can still use normal chat/RAG.
MONDAY_CLIENT_ID=d73f2043b2f64cf8df3bd7be70b3d253
MONDAY_CLIENT_SECRET=e23e0a7975dfe0e0c45cc2a1f27cc73c
# Must exactly match redirect URL configured in your Monday app.
MONDAY_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/integrations/monday/callback
# Space-separated scopes (adjust for your Monday app permissions)
MONDAY_OAUTH_SCOPES=me:read boards:read boards:write
# Required when Monday integration is enabled (used to encrypt per-user OAuth tokens at rest)
MONDAY_ENCRYPTION_KEY=orlanda-engineering_onboarding
